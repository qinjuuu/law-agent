# ============================================================
# 火山引擎 ARK 大模型配置
# ============================================================
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
MODEL_ID=doubao-seed-2-0-pro-260215

# ============================================================
# 嵌入模型配置（本地 sentence-transformers，无需 API Key）
# 首次运行会自动下载模型到 HuggingFace 缓存目录
# 国内网络可设置 HF_ENDPOINT=https://hf-mirror.com 加速
# ============================================================
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# ============================================================
# RAG 参数
# ============================================================
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=5
VECTOR_WEIGHT=0.7
BM25_WEIGHT=0.3

# ============================================================
# MySQL 数据库配置
# ============================================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=consumer_rights

# ============================================================
# SMTP 邮件发送配置（QQ邮箱）
# 用于发送投诉信、审查报告等维权文档
# SMTP_PASSWORD 是QQ邮箱授权码，非登录密码
# 在QQ邮箱 -> 设置 -> 账户 -> POP3/SMTP服务中获取
# ============================================================
SMTP_SERVER=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your_qq@qq.com
SMTP_PASSWORD=your_auth_code_here
